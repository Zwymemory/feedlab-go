{
  "info": {
    "name": "FeedLab Go V1 + V2",
    "description": "FeedLab Postman 测试流程。按模块顺序执行：健康检查 -> 注册 -> 登录 -> 当前用户 -> 发布帖子 -> 点赞 -> 评论 -> 删除 -> Swagger 文档。",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080"
    },
    {
      "key": "username",
      "value": ""
    },
    {
      "key": "email",
      "value": ""
    },
    {
      "key": "password",
      "value": "secret123"
    },
    {
      "key": "access_token",
      "value": ""
    },
    {
      "key": "user_id",
      "value": ""
    },
    {
      "key": "post_id",
      "value": ""
    },
    {
      "key": "comment_id",
      "value": ""
    },
    {
      "key": "reply_id",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Module 1 - Health Check",
      "item": [
        {
          "name": "GET /healthz",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/healthz",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "healthz"
              ]
            },
            "description": "检查 API、MySQL、Redis 是否可用。成功时 code=0；依赖未启动时 code=50000。"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Module 2 - Auth",
      "item": [
        {
          "name": "POST /api/v1/auth/register",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const suffix = Date.now();",
                  "pm.collectionVariables.set('username', `user_${suffix}`);",
                  "pm.collectionVariables.set('email', `user_${suffix}@feedlab.test`);",
                  "pm.collectionVariables.set('password', 'secret123');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\",\n  \"nickname\": \"FeedLab Tester\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "register"
              ]
            },
            "description": "注册用户。Pre-request 会生成唯一 username/email，避免重复邮箱冲突。"
          },
          "response": []
        },
        {
          "name": "POST /api/v1/auth/login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.access_token) {",
                  "  pm.collectionVariables.set('access_token', json.data.access_token);",
                  "}",
                  "if (json.data && json.data.user && json.data.user.id) {",
                  "  pm.collectionVariables.set('user_id', json.data.user.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "login"
              ]
            },
            "description": "用注册阶段保存的 email/password 登录。Test 脚本会保存 access_token。"
          },
          "response": []
        },
        {
          "name": "GET /api/v1/users/me",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/users/me",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "users",
                "me"
              ]
            },
            "description": "验证 JWT 鉴权闭环。必须先执行登录接口保存 access_token。"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Module 3 - Posts",
      "item": [
        {
          "name": "POST /api/v1/posts",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.id) {",
                  "  pm.collectionVariables.set('post_id', json.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"FeedLab V1 帖子测试\",\n  \"content\": \"这是通过 Postman 创建的第一篇帖子。\",\n  \"cover_url\": \"\",\n  \"content_type\": \"article\",\n  \"status\": \"published\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/posts",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "posts"
              ]
            },
            "description": "创建帖子。必须先执行登录接口保存 access_token。Test 脚本会保存 post_id。"
          },
          "response": []
        },
        {
          "name": "GET /api/v1/posts",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/posts?page=1&page_size=10",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "posts"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "page_size",
                  "value": "10"
                }
              ]
            },
            "description": "分页查看 published 帖子列表，不需要 Token。"
          },
          "response": []
        },
        {
          "name": "GET /api/v1/posts/:id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/posts/{{post_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "posts",
                "{{post_id}}"
              ]
            },
            "description": "查看刚创建的帖子详情，不需要 Token。"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Module 4 - Likes",
      "item": [
        {
          "name": "POST /api/v1/posts/:id/like",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/posts/{{post_id}}/like",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "posts",
                "{{post_id}}",
                "like"
              ]
            },
            "description": "点赞刚创建的帖子。必须先执行登录和创建帖子。"
          },
          "response": []
        },
        {
          "name": "POST /api/v1/posts/:id/like - idempotent",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/posts/{{post_id}}/like",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "posts",
                "{{post_id}}",
                "like"
              ]
            },
            "description": "重复点赞幂等测试。预期仍成功，但 like_count 不重复增加。"
          },
          "response": []
        },
        {
          "name": "GET /api/v1/posts/:id/liked",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/posts/{{post_id}}/liked",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "posts",
                "{{post_id}}",
                "liked"
              ]
            },
            "description": "查询当前用户是否点赞过该帖子。预期 liked=true。"
          },
          "response": []
        },
        {
          "name": "GET /api/v1/users/:id/likes",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/users/{{user_id}}/likes?page=1&page_size=10",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "users",
                "{{user_id}}",
                "likes"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "page_size",
                  "value": "10"
                }
              ]
            },
            "description": "查看当前用户点赞过的 published 帖子列表。"
          },
          "response": []
        },
        {
          "name": "DELETE /api/v1/posts/:id/like",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/posts/{{post_id}}/like",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "posts",
                "{{post_id}}",
                "like"
              ]
            },
            "description": "取消点赞。预期 liked=false，like_count 只在原本点赞时减少。"
          },
          "response": []
        },
        {
          "name": "DELETE /api/v1/posts/:id/like - idempotent",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/posts/{{post_id}}/like",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "posts",
                "{{post_id}}",
                "like"
              ]
            },
            "description": "重复取消点赞幂等测试。预期仍成功，但 like_count 不继续减少。"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Module 5 - Comments",
      "item": [
        {
          "name": "POST /api/v1/posts/:id/comments - root",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.id) {",
                  "  pm.collectionVariables.set('comment_id', json.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"这是通过 Postman 创建的一级评论。\",\n  \"parent_id\": 0\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/posts/{{post_id}}/comments",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "posts",
                "{{post_id}}",
                "comments"
              ]
            },
            "description": "发布一级评论。Test 脚本会保存 comment_id，posts.comment_count 应增加 1。"
          },
          "response": []
        },
        {
          "name": "POST /api/v1/posts/:id/comments - reply",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.id) {",
                  "  pm.collectionVariables.set('reply_id', json.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"这是通过 Postman 创建的二级回复。\",\n  \"parent_id\": {{comment_id}}\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/posts/{{post_id}}/comments",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "posts",
                "{{post_id}}",
                "comments"
              ]
            },
            "description": "回复刚创建的一级评论。Test 脚本会保存 reply_id，posts.comment_count 应再次增加 1。"
          },
          "response": []
        },
        {
          "name": "GET /api/v1/posts/:id/comments",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/posts/{{post_id}}/comments?page=1&page_size=10",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "posts",
                "{{post_id}}",
                "comments"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "page_size",
                  "value": "10"
                }
              ]
            },
            "description": "查看帖子一级评论列表。预期包含 comment_id，不包含二级回复。"
          },
          "response": []
        },
        {
          "name": "GET /api/v1/comments/:id/replies",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/comments/{{comment_id}}/replies?page=1&page_size=10",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "comments",
                "{{comment_id}}",
                "replies"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "page_size",
                  "value": "10"
                }
              ]
            },
            "description": "查看一级评论下的二级回复。预期包含 reply_id。"
          },
          "response": []
        },
        {
          "name": "DELETE /api/v1/comments/:id - reply",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/comments/{{reply_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "comments",
                "{{reply_id}}"
              ]
            },
            "description": "软删除刚创建的回复。预期 deleted_count=1。"
          },
          "response": []
        },
        {
          "name": "POST /api/v1/posts/:id/comments - reply before cascade",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.id) {",
                  "  pm.collectionVariables.set('reply_id', json.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"这是删除一级评论前重新创建的回复。\",\n  \"parent_id\": {{comment_id}}\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/posts/{{post_id}}/comments",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "posts",
                "{{post_id}}",
                "comments"
              ]
            },
            "description": "重新创建一条回复，用于测试删除一级评论时级联软删除未删除回复。"
          },
          "response": []
        },
        {
          "name": "DELETE /api/v1/comments/:id - root cascade",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/comments/{{comment_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "comments",
                "{{comment_id}}"
              ]
            },
            "description": "软删除一级评论，并级联软删除它下面未删除的回复。预期 deleted_count 至少为 1。"
          },
          "response": []
        },
        {
          "name": "GET /api/v1/posts/:id after comments",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/posts/{{post_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "posts",
                "{{post_id}}"
              ]
            },
            "description": "查看帖子详情，确认 comment_count 已按创建和删除评论的实际数量维护。"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Module 6 - Cleanup",
      "item": [
        {
          "name": "DELETE /api/v1/posts/:id",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/posts/{{post_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "posts",
                "{{post_id}}"
              ]
            },
            "description": "软删除刚创建的帖子。只有作者或 admin 可以删除。删除后再次点赞该帖子应返回 404。"
          },
          "response": []
        },
        {
          "name": "POST /api/v1/posts/:id/like after delete",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/posts/{{post_id}}/like",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "posts",
                "{{post_id}}",
                "like"
              ]
            },
            "description": "删除帖子后再次点赞，预期返回 40400。"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Module 7 - Swagger",
      "item": [
        {
          "name": "GET /swagger/index.html",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/swagger/index.html",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "swagger",
                "index.html"
              ]
            },
            "description": "打开可交互 Swagger UI。页面支持 Try it out、Authorize 填写 JWT，并可直接调用本地 API。"
          },
          "response": []
